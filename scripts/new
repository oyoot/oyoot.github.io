#!/usr/bin/env ruby
require "optparse"

TYPES = {
  "note"    => "_notes",
  "thought" => "_thoughts",
}

tags = []
parser = OptionParser.new do |opts|
  opts.banner = "Usage: scripts/new <note|thought> \"Title\" [--tags \"tag1, tag2\"]"
  opts.on("--tags TAGS", "Comma-separated list of tags") do |t|
    tags = t.split(",").map(&:strip).reject(&:empty?)
  end
end
parser.parse!(ARGV)

if ARGV.length < 2
  warn parser.banner
  exit 1
end

type  = ARGV.shift.downcase
title = ARGV.join(" ")

unless TYPES.key?(type)
  warn "Unknown type '#{type}'. Must be one of: #{TYPES.keys.join(', ')}"
  exit 1
end

root = File.expand_path("..", __dir__)
dir  = File.join(root, TYPES[type])
Dir.mkdir(dir) unless Dir.exist?(dir)

date = Time.now.strftime("%Y-%m-%d")
slug = title.downcase.strip.gsub(/[^\w\s-]/, "").gsub(/[\s_]+/, "-")
filename = "#{date}-#{slug}.md"
filepath = File.join(dir, filename)

if File.exist?(filepath)
  warn "Already exists: #{filepath}"
  exit 1
end

lines = [
  "---",
  "title: \"#{title}\"",
  "date: #{Time.now.strftime("%Y-%m-%d %H:%M:%S %z")}",
]
unless tags.empty?
  lines << "tags:"
  tags.each { |tag| lines << "  - #{tag}" }
end
lines << "---"
lines << ""

File.write(filepath, lines.join("\n"))
puts "Created #{TYPES[type]}/#{filename}"
